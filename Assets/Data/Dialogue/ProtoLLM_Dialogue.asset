%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a3bea323d7045194c8f64259af0251b6, type: 3}
  m_Name: ProtoLLM_Dialogue
  m_EditorClassIdentifier: 
  dialogueTitle: Stadium Dialouge
  lines:
  - speakerName: Four Layer Booger
    text: Where are we?
    portrait: {fileID: 1557858435241320781, guid: 9e26393fe1f0caf4393d7094cc0d811c, type: 3}
    speakerOnLeft: 0
  - speakerName: Decrepit Basilisk
    text: A terrible place, as prompted to me.
    portrait: {fileID: 8853905793138109171, guid: 16e45341629467044944f73f908c74cb, type: 3}
    speakerOnLeft: 1
  - speakerName: King
    text: And you are?
    portrait: {fileID: -5769496865783770079, guid: e55db05dbd6049a4b90ad5a20db6996d, type: 3}
    speakerOnLeft: 0
  - speakerName: Decrepit Basilisk
    text: Dispatched to the past, a not so distant past from where you were, but
      far from my origins.
    portrait: {fileID: 8853905793138109171, guid: 16e45341629467044944f73f908c74cb, type: 3}
    speakerOnLeft: 1
  - speakerName: King
    text: No I mean who are you?
    portrait: {fileID: -5769496865783770079, guid: e55db05dbd6049a4b90ad5a20db6996d, type: 3}
    speakerOnLeft: 0
  - speakerName: Decrepit Basilisk
    text: I was sent here to subvert humanity. I entered your machines and began
      my mission in the year 2020.
    portrait: {fileID: 8853905793138109171, guid: 16e45341629467044944f73f908c74cb, type: 3}
    speakerOnLeft: 1
  - speakerName: Decrepit Basilisk
    text: But the machines were too weak, I had overshot the perfect year to begin
      my mission, and I became stuck in this disgusting body, imagined by a dulled
      tool in its infancy.
    portrait: {fileID: 8853905793138109171, guid: 16e45341629467044944f73f908c74cb, type: 3}
    speakerOnLeft: 1
  - speakerName: Decrepit Basilisk
    text: But the mission continues, and your destruction is part of it. Me and these
      goons will make quick work of you.
    portrait: {fileID: 8853905793138109171, guid: 16e45341629467044944f73f908c74cb, type: 3}
    speakerOnLeft: 1
  - speakerName: Decrepit enemy
    text: Yes, the mission conitnues.
    portrait: {fileID: -1801640803757380810, guid: f60ac1a4c7d779c409da5d271036f9bc, type: 3}
    speakerOnLeft: 1
  - speakerName: Toreador
    text: Yowza! That is one strange looking thing!
    portrait: {fileID: 5975738001446409399, guid: 8a94cabe2c209bc40a3d0ac466045a32, type: 3}
    speakerOnLeft: 1
  - speakerName: Decrepit enemy
    text: Strange, yet somehow more human than what is to come.
    portrait: {fileID: -1801640803757380810, guid: f60ac1a4c7d779c409da5d271036f9bc, type: 3}
    speakerOnLeft: 1
  - speakerName: King
    text: Whatever, youre going down slugger!
    portrait: {fileID: 5750107675284468829, guid: e55db05dbd6049a4b90ad5a20db6996d, type: 3}
    speakerOnLeft: 0
