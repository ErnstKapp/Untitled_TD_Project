MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a3bea323d7045194c8f64259af0251b6, type: 3}
  m_Name: StadiumDialogue
  m_EditorClassIdentifier: 
  dialogueTitle: Stadium Dialouge
  lines:
  - speakerName: Four Layer Booger
    text: Hey, thanks for letting us be your warm-up act King! Was hard getting out
      here in the rain but we made it in one piece.
    portrait: {fileID: 1557858435241320781, guid: 9e26393fe1f0caf4393d7094cc0d811c, type: 3}
    speakerOnLeft: 0
  - speakerName: The King
    text: Glad to have you here boys! The rain out these parts are no joke, you lot
      seem all shook up haha!
    portrait: {fileID: -5769496865783770079, guid: e55db05dbd6049a4b90ad5a20db6996d, type: 3}
    speakerOnLeft: 1
  - speakerName: Four Layer Booger
    text: Whew no kidding! Did you see the setlist? Were planning to start with "My
      big mout-
    portrait: {fileID: 1557858435241320781, guid: 9e26393fe1f0caf4393d7094cc0d811c, type: 3}
    speakerOnLeft: 0
  - speakerName: Stranger
    text: '*CRASH*'
    portrait: {fileID: 7090464327165714005, guid: b6f0af1f44b4e1f49a5b9f8c262e02fb, type: 3}
    speakerOnLeft: 1
  - speakerName: Four Layer Booger
    text: Woah, show hasnt started yet pal, get back!
    portrait: {fileID: 2600253448845335413, guid: 9e26393fe1f0caf4393d7094cc0d811c, type: 3}
    speakerOnLeft: 0
  - speakerName: Stranger
    text: Im here to destroy you
    portrait: {fileID: 7090464327165714005, guid: b6f0af1f44b4e1f49a5b9f8c262e02fb, type: 3}
    speakerOnLeft: 1
  - speakerName: The King
    text: What the crack? Lets return these guys to their sender fellas!
    portrait: {fileID: 5622922139875535349, guid: e55db05dbd6049a4b90ad5a20db6996d, type: 3}
    speakerOnLeft: 0
